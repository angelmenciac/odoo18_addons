<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Heredar el formulario de contactos para agregar campos courier -->
    <record id="view_partner_courier_form" model="ir.ui.view">
        <field name="name">res.partner.courier.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="🚚 Courier / Envíos" name="courier_info">
                    <group>
                        <group string="Configuración de Destinatario">
                            <field name="is_courier_recipient"/>
                            <field name="is_public_recipient" readonly="1"
                                   invisible="not is_courier_recipient"/>
                        </group>
                        <group string="Estadísticas">
                            <field name="recipient_courier_count" readonly="1"/>
                        </group>
                    </group>

                    <!-- Clientes con acceso — visible solo si es destinatario -->
                    <div invisible="not is_courier_recipient">
                        <separator string="Clientes con acceso a este destinatario"/>
                        <p class="text-muted" style="font-size:0.9em; margin-bottom:8px;">
                            Selecciona los clientes que podrán ver este destinatario al crear envíos.
                            Si no seleccionas ninguno, será <strong>público</strong> para todos los clientes.
                        </p>
                        <field name="courier_owner_ids"
                               widget="many2many_tags"
                               domain="[('customer_rank', '>', 0)]"
                               placeholder="Vacío = público para todos los clientes"
                               options="{'no_create': True}"/>

                        <!-- Info dinámica según si tiene clientes o no -->
                        <div class="alert alert-success mt-2"
                             invisible="courier_owner_ids">
                            <i class="fa fa-globe me-2"/>
                            <strong>Destinatario Público:</strong>
                            Visible para todos los clientes de Transporte Conchita.
                        </div>
                        <div class="alert alert-info mt-2"
                             invisible="not courier_owner_ids">
                            <i class="fa fa-lock me-2"/>
                            <strong>Destinatario Privado/Compartido:</strong>
                            Solo visible para los clientes seleccionados arriba.
                        </div>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Acción: ver solo destinatarios de courier -->
    <record id="action_courier_recipients" model="ir.actions.act_window">
        <field name="name">Destinatarios de Envíos</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_courier_recipient', '=', True)]</field>
        <field name="context">{'default_is_courier_recipient': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay destinatarios registrados aún.
            </p>
            <p>
                Crea un contacto, activa "Es Destinatario de Envíos" y
                opcionalmente asigna clientes con acceso.
            </p>
        </field>
    </record>

    <!-- Menú: Destinatarios dentro del módulo courier -->
    <menuitem id="menu_courier_recipients"
              name="Destinatarios"
              parent="conchita_courier.menu_courier_main"
              action="action_courier_recipients"
              sequence="30"
              groups="conchita_courier.group_courier_operator"/>

</odoo>
