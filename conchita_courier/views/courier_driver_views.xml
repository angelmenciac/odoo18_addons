<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_courier_driver_list" model="ir.ui.view">
        <field name="name">courier.driver.list</field>
        <field name="model">courier.driver</field>
        <field name="arch" type="xml">
            <list string="Motoristas">
                <field name="name"/>
                <field name="phone"/>
                <field name="vehicle_type"/>
                <field name="license_plate"/>
                <field name="route_ids" widget="many2many_tags"/>
                <field name="delivery_count"/>
                <field name="pending_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_courier_driver_form" model="ir.ui.view">
        <field name="name">courier.driver.form</field>
        <field name="model">courier.driver</field>
        <field name="arch" type="xml">
            <form string="Motorista">
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_deliveries" type="object"
                                class="oe_stat_button" icon="fa-check-circle">
                            <field name="delivery_count" widget="statinfo"
                                   string="Entregados"/>
                        </button>
                        <button name="action_view_deliveries" type="object"
                                class="oe_stat_button" icon="fa-truck">
                            <field name="pending_count" widget="statinfo"
                                   string="Pendientes"/>
                        </button>
                    </div>
                    <group>
                        <group string="Datos Personales">
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="employee_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Vehículo">
                            <field name="vehicle_type"/>
                            <field name="license_plate"/>
                        </group>
                    </group>
                    <separator string="Zonas Habituales"/>
                    <field name="route_ids" widget="many2many_checkboxes"/>
                    <separator string="Notas"/>
                    <field name="note" placeholder="Observaciones sobre el motorista..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_courier_driver" model="ir.actions.act_window">
        <field name="name">Motoristas</field>
        <field name="res_model">courier.driver</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
