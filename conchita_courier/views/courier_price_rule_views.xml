<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_courier_price_rule_list" model="ir.ui.view">
        <field name="name">courier.price.rule.list</field>
        <field name="model">courier.price.rule</field>
        <field name="arch" type="xml">
            <list string="Reglas de Precio">
                <field name="route_id"/>
                <field name="weight_from"/>
                <field name="weight_to"/>
                <field name="price"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_courier_price_rule_form" model="ir.ui.view">
        <field name="name">courier.price.rule.form</field>
        <field name="model">courier.price.rule</field>
        <field name="arch" type="xml">
            <form string="Regla de Precio">
                <sheet>
                    <group>
                        <group>
                            <field name="route_id"/>
                            <field name="weight_from"/>
                            <field name="weight_to"/>
                            <field name="price"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Precios Especiales por Cliente"/>
                    <p class="text-muted">
                        Configura precios negociados para clientes específicos.
                        Estos precios sobreescriben el precio base para esa ruta y rango de peso.
                    </p>
                    <field name="partner_price_ids">
                        <list editable="bottom">
                            <field name="partner_id"/>
                            <field name="price"/>
                            <field name="note"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_courier_price_rule" model="ir.actions.act_window">
        <field name="name">Reglas de Precio</field>
        <field name="res_model">courier.price.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
