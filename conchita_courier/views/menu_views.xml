    <menuitem id="menu_courier_draft"
              name="Solicitudes Nuevas"
              parent="menu_courier_main"
              action="action_courier_request"
              sequence="20"/>

    <!-- Operaciones -->
    <menuitem id="menu_courier_operations"
              name="Operaciones"
              parent="menu_courier_root"
              sequence="20"
              groups="conchita_courier.group_courier_operator"/>

    <menuitem id="menu_courier_drivers"
              name="Motoristas"
              parent="menu_courier_operations"
              action="action_courier_driver"
              sequence="10"
              groups="conchita_courier.group_courier_operator"/>

    <!-- Configuración -->
    <menuitem id="menu_courier_config"
              name="Configuración"
              parent="menu_courier_root"
