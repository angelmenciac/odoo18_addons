<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════
         MENÚ PRINCIPAL
    ══════════════════════════════════════ -->
    <menuitem id="menu_courier_root"
              name="🚚 Encomiendas"
              sequence="10"
              web_icon="conchita_courier,static/src/img/icon.png"
              groups="conchita_courier.group_courier_user"/>

    <!-- Envíos -->
    <menuitem id="menu_courier_main"
              name="Envíos"
              parent="menu_courier_root"
              sequence="10"/>

    <menuitem id="menu_courier_all"
              name="Todos los Envíos"
              parent="menu_courier_main"
