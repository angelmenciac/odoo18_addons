    <menuitem id="menu_courier_routes"
              name="Zonas de Entrega"
              parent="menu_courier_config"
              action="action_courier_route"
              sequence="20"
              groups="conchita_courier.group_courier_manager"/>

    <menuitem id="menu_courier_prices"
              name="Reglas de Precio"
              parent="menu_courier_config"
              action="action_courier_price_rule"
              sequence="30"
              groups="conchita_courier.group_courier_manager"/>

